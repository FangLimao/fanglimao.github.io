{% from "_macro/ui.njk" import svg_filters %}
<!doctype html>
<html lang="{% if config.language is iterable and config.language is not string %}{{ config.language[0] }}{% else %}{{ config.language }}{% endif %}" class="h-full scroll-smooth">
{% include "_partial/common/head.njk" %}

<body class="h-full fog-bg text-slate-800">
    {% if theme.site.seal %}
    {{ svg_filters() }}
    {% endif %}

    {% if theme.progress_bar.enabled and (is_post() or is_page()) %}
    <div id="progressBar" class="progress-bar" aria-hidden="true"></div>
    {% endif %}

    <div class="min-h-full px-4 pt-14 pb-6 md:pb-5">

        <!-- Paper Card -->
        <div
            class="paper relative mx-auto w-full max-w-4xl rounded-xl px-5 sm:px-8 md:px-12 lg:px-14 pt-10 pb-6 md:pt-12 md:pb-8">

            {% include "_partial/common/header.njk" %}

            <!-- Main Content -->
            <main class="section-divider">
                {% block content %}{% endblock %}
            </main>

            {% include "_partial/common/footer.njk" %}
        </div>

        <!-- Note Text — decorative aside, not part of main content or footer -->
        <aside class="mt-4 text-center" aria-hidden="true" role="presentation">
            <p class="site-note font-title text-xs sm:text-sm text-slate-400/70 tracking-note font-light select-none" lang="ja">
                「请别哭泣，爱与热忱会生长如昔」
            </p>
        </aside>
    </div>

    {% if theme.back_to_top.enabled %}
    <button id="backToTop" class="back-to-top" data-visible="false" aria-label="{{ __('back_to_top') }}">
        <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
        </svg>
    </button>
    {% endif %}

    {% if theme.search.enabled %}
    {% include "_partial/components/search-modal.njk" %}
    <script>window.__pagefindBase = "{{ url_for('/pagefind/') }}";</script>
    {% endif %}

    <!-- Scripts -->
    {% set i18n_data = {
        clipboard_copy: __('clipboard_copy'),
        clipboard_copied: __('clipboard_copied'),
        gallery_visit_source: __('gallery_visit_source'),
        gallery_view_image: __('gallery_view_image'),
        search: {
            button: __('search.button'),
            placeholder: __('search.placeholder'),
            close: __('search.close'),
            zero_results: __('search.zero_results'),
            one_result: __('search.one_result'),
            many_results: __('search.many_results'),
            loading: __('search.loading')
        }
    } %}
    <script>window.__i18n = {{ i18n_data | dump | safe }};</script>
    {% if is_home() or is_post() or is_page() %}
    <script defer src="https://cdn.jsdelivr.net/npm/lightgallery@2.9.0/lightgallery.min.js" integrity="sha384-yshhQEAY0bBxbxfLyRlLQ7v1z45XofL6adlFh192s2NpDzXS+HPKjXoloaHiNcYO" crossorigin="anonymous"></script>
    <script defer src="{{ versioned_url('js/lightgallery.js') }}"></script>
    <script defer src="{{ versioned_url('js/clipboard.js') }}"></script>
    {% endif %}
    {% if theme.toc.enabled and (is_post() or is_page()) %}
    {% set toc_config = { depth: theme.toc.depth | default(3), minHeadings: theme.toc.min_headings | default(3) } %}
    <script>window.__tocConfig = {{ toc_config | dump | safe }};</script>
    <script defer src="{{ versioned_url('js/toc.js') }}"></script>
    {% endif %}
    {% set needs_progress_js = (theme.progress_bar.enabled and (is_post() or is_page())) or theme.back_to_top.enabled %}
    {% if needs_progress_js %}
    <script defer src="{{ versioned_url('js/progress.js') }}"></script>
    {% endif %}
    {% if theme.dark_mode.toggle != false %}
    <script defer src="{{ versioned_url('js/theme-toggle.js') }}"></script>
    {% endif %}
    {% if theme.menu and theme.menu.length %}
    <script defer src="{{ versioned_url('js/mobile-menu.js') }}"></script>
    {% endif %}
    {% if theme.search.enabled %}
    <script defer src="{{ versioned_url('js/search.js') }}"></script>
    {% endif %}
    {% include "_partial/analytics/google.njk" %}
</body>
</html>
