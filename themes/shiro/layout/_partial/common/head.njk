<head>
    <meta charset="utf-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta name="generator" content="Hexo {{ hexo.version }}" />
    <!-- FOUC prevention: apply dark mode class before first paint.
         Flow: read default → build valid states → read localStorage (try/catch for Safari private mode)
         → validate saved state → set data-theme-state on <html> → resolve effective dark/light
         → add .dark class and colorScheme if needed. -->
    <script>(function(){const d={{ theme.dark_mode.default | default("system", true) | dump | safe }};window.__themeDefault=d;const s=d==='system'?['system','light','dark']:['light','dark'];let sv;try{sv=localStorage.getItem('theme')}catch(e){}if(!sv||s.indexOf(sv)===-1)sv=d;const h=document.documentElement;h.setAttribute('data-theme-state',sv);const k=sv==='dark'||(sv!=='light'&&window.matchMedia('(prefers-color-scheme:dark)').matches);if(k)h.classList.add('dark');h.style.colorScheme=k?'dark':'light';})()</script>
    {% set google_fonts_url = "https://fonts.googleapis.com/css2?family=Cardo:wght@400;700&display=swap&family=Yuji+Syuku&display=optional&family=Zen+Old+Mincho:wght@400;600&display=swap&family=Noto+Serif+JP:wght@400;600&display=swap&family=Noto+Serif+SC:wght@400;600&display=swap&family=Cormorant+Garamond:wght@400;600&display=swap&family=Fira+Code:wght@400;500&display=swap" %}
    <link rel="stylesheet" href="{{ google_fonts_url }}" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {# --- SEO Variables --- #}
    {% set site_title = config.title %}
    {% set page_title = build_page_title(page, config) %}
    {% set clean_desc = clean_description(page, config) %}
    {% set og_img = og_image(page) %}
    <title>{{ page_title }}</title>

    <!-- SEO Meta -->
    {% if clean_desc %}
    <meta name="description" content="{{ clean_desc }}" />
    {% endif %}
    {% if page.author or config.author %}
    <meta name="author" content="{{ page.author or config.author }}" />
    {% endif %}
    {% if page.keywords %}
    <meta name="keywords" content="{{ page.keywords }}" />
    {% elif page.tags and page.tags.length %}
    <meta name="keywords" content="{% for tag in page.tags.toArray() %}{{ tag.name }}{% if not loop.last %}, {% endif %}{% endfor %}" />
    {% elif config.keywords %}
    <meta name="keywords" content="{{ config.keywords }}" />
    {% endif %}

    <!-- Open Graph -->
    <meta property="og:title" content="{{ page_title }}" />
    {% if clean_desc %}
    <meta property="og:description" content="{{ clean_desc }}" />
    {% endif %}
    <meta property="og:url" content="{{ url }}" />
    <meta property="og:type" content="{% if is_post() %}article{% else %}website{% endif %}" />
    <meta property="og:site_name" content="{{ site_title }}" />
    {% if og_img %}
    <meta property="og:image" content="{{ og_img }}" />
    {% endif %}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="{% if og_img %}summary_large_image{% else %}summary{% endif %}" />
    <meta name="twitter:title" content="{{ page_title }}" />
    {% if clean_desc %}
    <meta name="twitter:description" content="{{ clean_desc }}" />
    {% endif %}
    {% if og_img %}
    <meta name="twitter:image" content="{{ og_img }}" />
    {% endif %}

    <!-- Canonical URL -->
    <link rel="canonical" href="{{ url }}" />

    <!-- Favicon -->
    {% if theme.site.favicon %}
    <link rel="icon" href="{{ url_for(theme.site.favicon) }}" />
    {% endif %}

    <!-- RSS -->
    {% if theme.site.rss.enabled %}
    <link rel="alternate" type="application/atom+xml" title="{{ config.title }}" href="{{ url_for(theme.site.rss.path | default('/atom.xml')) }}" />
    {% endif %}

    <!-- CSS -->
    {% if is_home() or is_post() or is_page() %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lightgallery@2.9.0/css/lightgallery.min.css" integrity="sha384-YlypU+LX5577RgeZebpBZTy28roXf0lHGaOSxrroczh16ktxM0BoAMPXsrehqxx8" crossorigin="anonymous" />
    {% endif %}
    <link rel="stylesheet" href="{{ versioned_url('css/style.min.css') }}">
</head>
